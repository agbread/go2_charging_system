<sdf version="1.7">
  <world name="aruco_docking_world">
    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_update_rate>1000</real_time_update_rate>
      <ode>
        <solver><iters>150</iters><sor>1.3</sor></solver>
        <constraints><erp>0.2</erp><cfm>0.0</cfm></constraints>
      </ode>
    </physics>

    <scene>
      <ambient>0.8 0.8 0.8 1</ambient>
      <background>0.3 0.3 0.3 1</background>
      <grid>false</grid>
    </scene>

    <include><uri>model://sun</uri></include>
    <include><uri>model://ground_plane</uri></include>

    <!--
      ArUco marker board (DICT_4X4_50, ID=0, 0.20m physical size).
      Placed 2.5 m in front of robot spawn (x=0).
      Yaw=pi so the +X face of the box (correct OGRE UV) faces the robot.
      Center height z=0.4 m matches the camera height when Go2 stands on flat ground.
    -->
    <include>
      <uri>model://aruco_marker_board</uri>
      <name>aruco_marker_0</name>
      <pose>2.5 0 0 0 0 3.14159265</pose>
    </include>

  </world>
</sdf>
